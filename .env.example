# MongoDB (required for live ingestion and cache refresh)
MONGODB_URI=mongodb+srv://...
MONGODB_DATABASE=gk-reports
MONGODB_COLLECTION_ROULETTE_REPORT=roulette_game_report

# Optional: leave unset to use local ./mlruns
MLFLOW_TRACKING_URI=

# Optional: Prefect Cloud (Phase 3 orchestration only)
PREFECT_API_URL=
PREFECT_API_KEY=
PREFECT_POOL_NAME=fraud-pool

# Optional: Slack notifications for Prefect flow failures
SLACK_WEBHOOK_URL=
